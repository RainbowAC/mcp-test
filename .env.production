# .env.production
# 生产环境配置

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# 数据库配置
DATABASE_HOST=db
DATABASE_PORT=3306
DATABASE_USER=mcp_user
DATABASE_PASSWORD=secure_password
DATABASE_NAME=mcp_production

# 环境标识
ENVIRONMENT=production

# 日志级别
LOG_LEVEL=WARNING

# 安全密钥 - 在生产环境中必须设置强密钥
SECRET_KEY=very_secure_secret_key_change_this_in_production

# 数据库连接池配置
POOL_SIZE=20
MAX_OVERFLOW=40
POOL_RECYCLE=3600