# .env.development
# 开发环境配置

# 服务器配置
SERVER_HOST=localhost
SERVER_PORT=3000

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_NAME=mcp_dev

# 环境标识
ENVIRONMENT=development

# 日志级别
LOG_LEVEL=DEBUG

# 安全密钥
SECRET_KEY=dev_secret_key_for_development

# 数据库连接池配置
POOL_SIZE=5
MAX_OVERFLOW=10
POOL_RECYCLE=3600